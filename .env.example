APP_ENV=development
USE_MOCK_COMPANY_LOOKUP=true

# MySQL admin storage
# Example local credentials; use your real local values in .env
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=nyskick_admin
MYSQL_USER=nyskick_user
MYSQL_PASSWORD=change_me
MYSQL_CHARSET=utf8mb4

# Bolagsverket company lookup
# Legacy API-key style:
# Supports either a path placeholder:
# BOLAGSVERKET_API_URL=https://example.bolagsverket.se/company/{orgnr}
# or a query-based endpoint:
# BOLAGSVERKET_API_URL=https://example.bolagsverket.se/company
BOLAGSVERKET_API_URL=
BOLAGSVERKET_API_KEY=
BOLAGSVERKET_API_AUTH_HEADER=X-API-Key
BOLAGSVERKET_API_AUTH_PREFIX=

# OAuth/client-credentials style:
BOLAGSVERKET_TOKEN_URL=
BOLAGSVERKET_CLIENT_ID=
BOLAGSVERKET_CLIENT_SECRET=
BOLAGSVERKET_API_BASE_URL=
BOLAGSVERKET_SCOPE=vardefulla-datamangder:read

# Fortnox export
USE_MOCK_FORTNOX=false
FORTNOX_API_BASE_URL=https://api.fortnox.se/3
FORTNOX_ACCESS_TOKEN=
FORTNOX_CLIENT_SECRET=
FORTNOX_DEBUG_PREVIEW=false

# Admin login
NYSKICK_ADMIN_USER=admin
NYSKICK_ADMIN_PASS=nyskick123

# Public address autocomplete
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_AUTOCOMPLETE_COUNTRY=se
